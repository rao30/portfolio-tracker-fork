{
  "name": "rental-snowball",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Rental property snowball payoff simulator for Railway deployment",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server.js",
    "dev:all": "concurrently -n vite,api -c cyan,magenta \"vite\" \"node server.js\"",
    "build:analytics": "esbuild server/analytics-entry.ts --bundle --platform=node --format=esm --outfile=server/portfolio-analytics.mjs",
    "build:mcp": "esbuild mcp-server/index.ts --bundle --platform=node --format=esm --outfile=mcp-server/dist/index.js --packages=external",
    "build": "npm run build:analytics && vite build && npm run build:mcp",
    "typecheck": "tsc -b",
    "check": "npm run typecheck && npm test",
    "start": "node server.js",
    "mcp": "node mcp-server/dist/index.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.106.2",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "concurrently": "^9.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
