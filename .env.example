# Supabase (Railway production — server only, never commit real keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: require this token on PUT /api/portfolio (Bearer or X-Portfolio-Key header)
PORTFOLIO_WRITE_KEY=

# Optional: same value as PORTFOLIO_WRITE_KEY if you enable write protection (Vite embeds at build time)
VITE_PORTFOLIO_WRITE_KEY=
