# Supabase (Railway production — server only, never commit real keys)
SUPABASE_URL=https://your-project.supabase.co
# Use new secret key (preferred) or legacy service_role JWT
SUPABASE_SECRET_KEY=your-sb-secret-key
SUPABASE_SERVICE_ROLE_KEY=

# Required for MCP + protected API (GET portfolio, POST /api/analyze, PUT /api/portfolio)
# Generate: openssl rand -hex 32
PORTFOLIO_API_KEY=

# Legacy alias — still works if PORTFOLIO_API_KEY is unset
PORTFOLIO_WRITE_KEY=

# Optional: same as PORTFOLIO_API_KEY for browser reads/writes (embedded at Vite build time)
VITE_PORTFOLIO_API_KEY=
VITE_PORTFOLIO_WRITE_KEY=

# Local stdio MCP server (.cursor/mcp.json) — your Railway public URL
PORTFOLIO_TRACKER_URL=

# Hosted MCP endpoint for Cursor Cloud config:
# https://portfolio-tracker-production-b019.up.railway.app/mcp
# Cursor: X-Portfolio-Key or Authorization: Bearer <PORTFOLIO_API_KEY>
# Supabase Auth (browser — anon/publishable key from project API settings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server JWT verification (same anon key, or SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=

# One-time admin bootstrap (scripts/bootstrap-user.mjs) — do not commit passwords
ADMIN_EMAIL=
ADMIN_PASSWORD=

# RentCast AVM for market value refresh (Zillow-style; free tier at rentcast.io/api)
RENTCAST_API_KEY=
